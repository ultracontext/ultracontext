{
  "name": "ultracontext-monorepo",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "check": "pnpm -r --if-present run check",
    "dev:sync": "pnpm --filter @ultracontext/sync run dev",
    "ultracontext:api": "pnpm --filter ultracontext-api run dev",
    "ultracontext:db:up": "cd apps/postgres && docker compose up -d",
    "ultracontext:db:down": "cd apps/postgres && docker compose down",
    "ultracontext:db:reset": "cd apps/postgres && docker compose down -v && docker compose up -d",
    "ultracontext:db:migrate": "bash ./apps/postgres/scripts/ultracontext-db-migrate.sh",
    "ultracontext:key:local": "bash ./apps/api/scripts/ultracontext-dev-key.sh",
    "ultracontext:migrate": "pnpm run ultracontext:db:migrate",
    "ultracontext:sync": "pnpm --filter @ultracontext/sync run start",
    "ultracontext:stop": "pnpm --filter @ultracontext/sync run stop"
  }
}
